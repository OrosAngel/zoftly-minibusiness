        {
            "id": "aabb0003-call-zoftly-api",
            "name": "Call Zoftly API",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                2780,
                400
            ],
            "parameters": {
                "url": "={{ $json.apiUrl }}",
                "method": "={{ $json.method }}",
                "options": {},
                "sendBody": true,
                "sendHeaders": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "=",
                            "value": "="
                        }
                    ]
                },
                "specifyBody": "json",
                "jsonBody": "={{ $json.body }}",
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $json.apiKey }}"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                }
            },
            "continueOnFail": true,
            "typeVersion": 4.2
        },
        {
            "id": "aabb0004-format-result",
            "name": "Format Result",
            "type": "n8n-nodes-base.code",
            "position": [
                2980,
                400
            ],
            "parameters": {
                "jsCode": "const apiResponse = $input.item.json;\nconst cleanMessage = $('Parse Action').item.json.cleanMessage;\nconst actionType = $('Parse Action').item.json.actionType;\n\nlet resultText = '';\n\nif (apiResponse.success) {\n  if (actionType === 'sell' && apiResponse.sale) {\n    resultText = '✅ Venta registrada:\\n';\n    for (const item of apiResponse.sale.items) {\n      resultText += `• ${item.quantity}x ${item.product_name} — S/ ${item.subtotal.toFixed(2)}\\n`;\n    }\n    resultText += `─────────────\\nTotal: S/ ${apiResponse.sale.total_amount.toFixed(2)} (${apiResponse.sale.payment_method})`;\n  } else if (actionType === 'stock' && apiResponse.product) {\n    const p = apiResponse.product;\n    resultText = `✅ Stock actualizado:\\n${p.name}: ${p.previous_stock} → ${p.new_stock} unidades`;\n  } else if (actionType === 'products' && apiResponse.products) {\n    resultText = `📦 Productos encontrados (${apiResponse.count}):\\n`;\n    for (const p of apiResponse.products.slice(0, 10)) {\n      const warn = p.low_stock ? ' ⚠️' : '';\n      resultText += `• ${p.name} — S/ ${p.price.toFixed(2)} — Stock: ${p.stock}${warn}\\n`;\n    }\n  } else {\n    resultText = '✅ ' + (apiResponse.message || 'Operación completada');\n  }\n} else {\n  resultText = '❌ ' + (apiResponse.error || 'Error al procesar la operación');\n}\n\n// Combinar mensaje del asistente con resultado\nlet finalMessage = '';\nif (cleanMessage) {\n  finalMessage = cleanMessage + '\\n\\n' + resultText;\n} else {\n  finalMessage = resultText;\n}\n\nreturn [{ json: { text: finalMessage } }];\n"
            },
            "typeVersion": 2
        },
