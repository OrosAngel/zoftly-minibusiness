        {
            "id": "aabb0001-parse-action-code-node",
            "name": "Parse Action",
            "type": "n8n-nodes-base.code",
            "position": [
                2380,
                500
            ],
            "parameters": {
                "jsCode": "// Obtener respuesta del asistente OpenAI\nconst messages = $('OPENAI - Get messages').item.json;\nconst responseText = messages.data[0].content[0].text.value;\nconst apiKey = $('Find User').item.json.api_key;\n\n// Detectar si hay una acción de Zoftly en la respuesta\nconst actionMatch = responseText.match(/\\[ZOFTLY_ACTION\\]([\\s\\S]*?)\\[\\/ZOFTLY_ACTION\\]/);\n\nif (actionMatch) {\n  try {\n    const action = JSON.parse(actionMatch[1].trim());\n    const cleanMessage = responseText.replace(/\\[ZOFTLY_ACTION\\][\\s\\S]*?\\[\\/ZOFTLY_ACTION\\]/, '').trim();\n    \n    // Determinar URL y método según la acción\n    // IMPORTANTE: Cambiar esta URL por la URL de tu app Zoftly desplegada\n    const BASE_URL = 'https://TU-ZOFTLY-URL.com';\n    let apiUrl = '';\n    let method = 'POST';\n    let body = {};\n    \n    if (action.action === 'sell') {\n      apiUrl = BASE_URL + '/api/automation/sell';\n      body = {\n        items: action.items,\n        payment_method: action.payment_method || 'EFECTIVO',\n        customer_id: action.customer_id || null\n      };\n    } else if (action.action === 'stock') {\n      apiUrl = BASE_URL + '/api/automation/stock';\n      body = {\n        product_name: action.product_name,\n        barcode: action.barcode,\n        action: action.action_type,\n        quantity: action.quantity\n      };\n    } else if (action.action === 'products') {\n      apiUrl = BASE_URL + '/api/automation/products' + (action.search ? '?search=' + encodeURIComponent(action.search) : '');\n      method = 'GET';\n    }\n    \n    return [{\n      json: {\n        hasAction: true,\n        apiUrl,\n        method,\n        body: JSON.stringify(body),\n        apiKey,\n        cleanMessage,\n        actionType: action.action\n      }\n    }];\n  } catch (e) {\n    return [{ json: { hasAction: false, message: responseText } }];\n  }\n} else {\n  return [{ json: { hasAction: false, message: responseText } }];\n}\n"
            },
            "typeVersion": 2
        },
